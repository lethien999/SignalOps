# Environment variables for SignalOps

# ===== API Gateway =====
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0

# ===== MongoDB =====
MONGODB_URI=mongodb://mongodb:27017/signalops-db
MONGODB_USERNAME=signalops
MONGODB_PASSWORD=secret123
MONGODB_INITDB_DATABASE=signalops-db

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== BullMQ Queue =====
QUEUE_EVENT_PROCESSING=event-processing
QUEUE_ALERT_NOTIFICATION=alert-notification

# ===== Logger =====
LOG_LEVEL=debug
LOG_FORMAT=json

# ===== Environment =====
NODE_ENV=development

# ===== Worker Service =====
WORKER_CONCURRENCY=5
WORKER_MAX_ATTEMPTS=3
WORKER_BACKOFF_DELAY=5000

# ===== Simulator =====
SIMULATOR_DEVICES_COUNT=10
SIMULATOR_INTERVAL_MS=5000
SIMULATOR_API_URL=http://api-gateway:3000

# ===== Alert Thresholds =====
THRESHOLD_LATENCY_MS=200
THRESHOLD_PACKET_LOSS_PERCENT=5
THRESHOLD_SIGNAL_STRENGTH_DBM=-90

# ===== JWT (Optional) =====
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h

# ===== CORS =====
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# ===== WebSocket =====
WEBSOCKET_ENABLE=true
WEBSOCKET_NAMESPACE=/socket.io

# ===== Monitoring =====
METRICS_ENABLE=false
PROMETHEUS_PORT=9090
