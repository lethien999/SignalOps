# SignalOps - Production Environment Template
# Copy to .env.production and fill in real values

# ===== Environment =====
NODE_ENV=production

# ===== API Gateway =====
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0
API_KEY=your-secure-api-key-min-32-chars
ADMIN_API_KEY=your-secure-admin-key-min-32-chars

# ===== MongoDB (Production) =====
# Use managed service (Atlas, DocumentDB) or self-hosted with auth
MONGODB_URI=mongodb://signalops:password@mongodb-prod:27017/signalops-db?authSource=admin&ssl=true
MONGODB_USERNAME=signalops
MONGODB_PASSWORD=your-secure-mongodb-password
MONGODB_INITDB_DATABASE=signalops-db

# ===== Redis (Production) =====
# Use managed service (ElastiCache) or self-hosted
REDIS_HOST=redis-prod.example.com
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password
REDIS_DB=0

# ===== JWT & Auth =====
JWT_SECRET=your-secure-jwt-secret-min-32-chars
JWT_EXPIRATION=24h

# ===== Worker Service =====
WORKER_CONCURRENCY=10          # Adjust based on CPU cores
WORKER_MAX_ATTEMPTS=3
QUEUE_EVENT_PROCESSING=event-processing
AUTO_RESOLVE_MIN_OPEN_MINUTES=2

# ===== M13: AI Anomaly Detection =====
ANOMALY_THRESHOLD=80           # ML decision threshold (0-100)

# A/B Test Configuration
# Giai đoạn 1 (Shadow): AI_ROLLOUT_PERCENT=0 (AI scores but no alerts)
# Giai đoạn 2 (Early):  AI_ROLLOUT_PERCENT=5 (5% of events use AI)
# Giai đoạn 3 (Scaled): AI_ROLLOUT_PERCENT=25 (25% of events)
# Giai đoạn 4 (Gradual): AI_ROLLOUT_PERCENT=50,75,90 (gradually increase)
# Giai đoạn 5 (Full): AI_ROLLOUT_PERCENT=100 (100% use AI)
AI_AB_TEST=true                # Enable A/B testing infrastructure
AI_ROLLOUT_PERCENT=0           # Start with shadow mode (0%)

# ===== Alert Thresholds (Rule-based Detection) =====
THRESHOLD_LATENCY_MS=200       # Warning level (ms)
THRESHOLD_PACKET_LOSS_PERCENT=5 # Warning level (%)
THRESHOLD_SIGNAL_STRENGTH_DBM=-90 # Warning level (dBm)

# ===== Logging =====
LOG_LEVEL=info                 # Use 'info' for production (not debug)
LOG_FORMAT=json

# ===== CORS =====
CORS_ORIGIN=https://yourdomain.com,https://app.yourdomain.com

# ===== Monitoring =====
METRICS_ENABLE=true
PROMETHEUS_PORT=9090

# ===== WebSocket =====
WEBSOCKET_ENABLE=true
WEBSOCKET_NAMESPACE=/socket.io

# ===== Optional: Maintenance =====
# Set to true to suppress all alerts during maintenance window
MAINTENANCE_MODE=false

# ===== Backup & Retention =====
# Number of days to retain event logs in MongoDB
EVENT_RETENTION_DAYS=90

# ===== Performance Tuning =====
# Connection pool size for MongoDB
MONGOOSE_MAX_POOL_SIZE=20

# Redis connection pool
REDIS_MAX_CONNECTIONS=50
