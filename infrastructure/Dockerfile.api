# Dockerfile for API Gateway service
FROM node:18-alpine

WORKDIR /app

# Copy workspace
COPY package.json ./
COPY tsconfig.json ./
COPY apps/api-gateway ./apps/api-gateway
COPY libs ./libs

# Install dependencies
RUN npm install

# Build
RUN npm run build -w api-gateway

# Runtime
EXPOSE 3000

CMD ["node", "dist/apps/api-gateway/main.js"]
