{
  "name": "signalops",
  "version": "1.0.0",
  "description": "SignalOps - Smart Telecom Monitoring System",
  "author": "SignalOps Team",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "npm --workspaces run build",
    "start": "npm --workspaces run start",
    "dev": "node scripts/dev.mjs",
    "dev:api-gateway": "npm run dev -w api-gateway",
    "dev:worker": "npm run dev -w worker-service",
    "dev:simulator": "npm run dev -w simulator",
    "dev:dashboard": "npm run dev -w dashboard",
    "test": "npm --workspaces run test",
    "test:integration": "npm run verify:api && npm run verify:websocket",
    "lint": "npm --workspaces run lint",
    "verify:api": "node scripts/verify-api.mjs",
    "verify:websocket": "node scripts/verify-websocket.mjs",
    "perf:load": "node scripts/perf-load.mjs",
    "perf:soak": "node scripts/perf-load.mjs",
    "perf:websocket": "node scripts/perf-websocket.mjs",
    "eval:ai": "node scripts/eval-ai-scoring.mjs",
    "gen:training-dataset": "node scripts/gen-training-dataset.mjs",
    "db:migrate": "npm run -w api-gateway db:migrate",
    "db:rollback": "npm run -w api-gateway db:rollback",
    "db:seed": "npm run -w api-gateway db:seed",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "docker:build": "docker compose --env-file .env -f infrastructure/docker-compose.yml build",
    "docker:up": "docker compose --env-file .env -f infrastructure/docker-compose.yml up -d",
    "docker:down": "docker compose --env-file .env -f infrastructure/docker-compose.yml down",
    "docker:logs": "docker compose --env-file .env -f infrastructure/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/passport-github2": "^1.2.9",
    "@types/passport-google-oauth20": "^2.0.17",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "socket.io-client": "^4.7.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@nestjs/passport": "^11.0.5",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0"
  }
}
